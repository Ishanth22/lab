

## **1. Airline Flight Information (with Constraints)**

```sql
CREATE TABLE Flights (
    flno NUMBER,
    from_city VARCHAR2(20),
    to_city VARCHAR2(20),
    distance NUMBER CHECK (distance > 0),
    departs VARCHAR2(10),
    arrives VARCHAR2(10),
    price NUMBER(8,2) CHECK (price > 0),
    CONSTRAINT pk_flights PRIMARY KEY (flno)
);
```

```sql
CREATE TABLE Aircraft (
    aid NUMBER,
    aname VARCHAR2(20) NOT NULL,
    cruisingrange NUMBER CHECK (cruisingrange > 0),
    CONSTRAINT pk_aircraft PRIMARY KEY (aid)
);
```

```sql
CREATE TABLE Employees (
    eid NUMBER,
    ename VARCHAR2(20) NOT NULL,
    salary NUMBER CHECK (salary > 0),
    CONSTRAINT pk_employees PRIMARY KEY (eid)
);
```

```sql
CREATE TABLE Certified (
    eid NUMBER,
    aid NUMBER,
    CONSTRAINT pk_certified PRIMARY KEY (eid, aid),
    CONSTRAINT fk_cert_emp FOREIGN KEY (eid) REFERENCES Employees(eid),
    CONSTRAINT fk_cert_air FOREIGN KEY (aid) REFERENCES Aircraft(aid)
);
```

