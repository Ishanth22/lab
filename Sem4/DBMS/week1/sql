## **3. Employee Database (with Constraints)**

```sql
CREATE TABLE Employee (
    empname VARCHAR2(20),
    street VARCHAR2(30),
    city VARCHAR2(20),
    CONSTRAINT pk_employee PRIMARY KEY (empname)
);
```

```sql
CREATE TABLE Company (
    companyname VARCHAR2(20),
    city VARCHAR2(20),
    CONSTRAINT pk_company PRIMARY KEY (companyname)
);
```

```sql
CREATE TABLE Works (
    empname VARCHAR2(20),
    companyname VARCHAR2(20),
    salary NUMBER CHECK (salary > 0),
    CONSTRAINT pk_works PRIMARY KEY (empname, companyname),
    CONSTRAINT fk_work_emp FOREIGN KEY (empname) REFERENCES Employee(empname),
    CONSTRAINT fk_work_comp FOREIGN KEY (companyname) REFERENCES Company(companyname)
);
```

```sql
CREATE TABLE Manages (
    empname VARCHAR2(20),
    managername VARCHAR2(20),
    CONSTRAINT pk_manages PRIMARY KEY (empname)
);
```

